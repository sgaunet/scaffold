name: lint

on:
  push:
  pull_request:

jobs:
  lint:
    runs-on: docker
    continue-on-error: true
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Cache mise tools
        uses: actions/cache@v4
        with:
          path: |
            ~/.local/share/mise
            ~/.cache/mise
          key: mise-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('mise.toml') }}
          restore-keys: |
            mise-${{ runner.os }}-${{ runner.arch }}-

      - name: Cache Go build & modules
        uses: actions/cache@v4
        with:
          path: |
            ~/go/pkg/mod
            ~/.cache/go-build
          key: go-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('go.sum') }}
          restore-keys: |
            go-${{ runner.os }}-${{ runner.arch }}-

      - name: Install prerequisites
        run: |
          curl https://mise.run | sh
          export PATH="$HOME/.local/bin:$PATH"
          mise trust
          mise install
        env:
          MISE_YES: "1"

      - name: Lint
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          mise exec -- task lint
        env:
          MISE_YES: "1"
