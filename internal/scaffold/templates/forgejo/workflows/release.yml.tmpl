name: release

on:
  push:
    # Pattern matched against refs/tags
    tags:
      - '**'

permissions:
  contents: write
  packages: write

jobs:
  goreleaser-release:
    runs-on: docker
    steps:
      -
        name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Cache mise tools
        uses: actions/cache@v4
        with:
          path: |
            ~/.local/share/mise
            ~/.cache/mise
          key: mise-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('mise.toml') }}
          restore-keys: |
            mise-${{ runner.os }}-${{ runner.arch }}-

      - name: Cache Go build & modules
        uses: actions/cache@v4
        with:
          path: |
            ~/go/pkg/mod
            ~/.cache/go-build
          key: go-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('go.sum') }}
          restore-keys: |
            go-${{ runner.os }}-${{ runner.arch }}-

      - name: Install prerequisites
        run: |
          curl https://mise.run | sh
          export PATH="$HOME/.local/bin:$PATH"
          mise trust
          mise install
        env:
          MISE_YES: "1"

      - name: create release
        run: |
          export PATH="$HOME/.local/bin:$PATH"
[[ if .Docker ]]
          echo "${{ secrets.CI_TOKEN }}" | mise exec -- docker login [[ .Host ]] -u "${REGISTRY_USER}" --password-stdin
[[ end ]]
          mise exec -- goreleaser release --clean --skip=homebrew
        env:
          MISE_YES: "1"
          GITEA_TOKEN: ${{ secrets.CI_TOKEN }}
          GITHUB_TOKEN: ""
          REGISTRY_USER: ${{ github.actor }}
          # Your GoReleaser Pro key, if you are using the 'goreleaser-pro' distribution
          # GORELEASER_KEY: ${{ secrets.GORELEASER_KEY }}
