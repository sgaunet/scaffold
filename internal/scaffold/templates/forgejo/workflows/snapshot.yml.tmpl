name: snapshot

on:
  pull_request:
  push:

jobs:
  goreleaser-snapshot:
    runs-on: docker
    steps:
      -
        name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Cache mise tools
        uses: actions/cache@v4
        with:
          path: |
            ~/.local/share/mise
            ~/.cache/mise
          key: mise-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('mise.toml') }}
          restore-keys: |
            mise-${{ runner.os }}-${{ runner.arch }}-

      - name: Cache Go build & modules
        uses: actions/cache@v4
        with:
          path: |
            ~/go/pkg/mod
            ~/.cache/go-build
          key: go-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('go.sum') }}
          restore-keys: |
            go-${{ runner.os }}-${{ runner.arch }}-

      - name: Install prerequisites
        run: |
          curl https://mise.run | sh
          export PATH="$HOME/.local/bin:$PATH"
          mise trust
          mise install
        env:
          MISE_YES: "1"

  #     - name: Login to GitHub Container Registry
  #       uses: docker/login-action@v3
  #       with:
  #         registry: ghcr.io
  #         username: ${{ github.actor }}
  #         password: ${{ secrets.GITHUB_TOKEN }}

      - name: create snapshot
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          mise exec -- task snapshot
        env:
          MISE_YES: "1"
          GITEA_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GITHUB_TOKEN: ""
          # Your GoReleaser Pro key, if you are using the 'goreleaser-pro' distribution
          # GORELEASER_KEY: ${{ secrets.GORELEASER_KEY }}
